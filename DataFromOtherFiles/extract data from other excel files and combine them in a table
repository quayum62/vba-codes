Sub Extract_QUIP_CAPA_Data()

    Dim folderPath As String
    Dim fileName As String
    Dim wb As Workbook
    Dim wsSource As Worksheet
    Dim wsDest As Worksheet
    
    Dim outputRow As Long
    Dim i As Long
    Dim caRow As Long, paRow As Long
    Dim localID As String
    
    Dim totalFiles As Long
    Dim currentFile As Long
    Dim progressPct As Double
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    folderPath = "C:\Users\bxb9893\OneDrive - JT International\Documents\!Tahseen Quayum\5000 IMS & QMS\QUIP\All QUIP CAPAs\"
    
    Set wsDest = ActiveSheet
    
    outputRow = 2
    
    wsDest.Range("A2:J" & wsDest.Rows.Count).ClearContents
    
    
    'Count files first
    fileName = Dir(folderPath & "*.xls*")
    
    Do While fileName <> ""
        totalFiles = totalFiles + 1
        fileName = Dir
    Loop
    
    
    'Show loading screen
    frmLoading.lblStatus.Caption = "Starting..."
    frmLoading.lblBar.Width = 0
    frmLoading.Show vbModeless
    
    
    fileName = Dir(folderPath & "*.xls*")
    
    Do While fileName <> ""
        
        currentFile = currentFile + 1
        
        progressPct = currentFile / totalFiles
        
        frmLoading.lblStatus.Caption = _
            "Processing " & currentFile & " of " & totalFiles & vbCrLf & fileName
            
        frmLoading.lblBar.Width = progressPct * 200
        
        DoEvents
        
        
        If folderPath & fileName <> ThisWorkbook.FullName Then
            
            Set wb = Workbooks.Open(folderPath & fileName, ReadOnly:=True)
            Set wsSource = wb.Worksheets(1)
            
            localID = Left(fileName, InStrRev(fileName, ".") - 1)
            
            
            For i = 0 To 5
                
                caRow = 43 + i
                paRow = 52 + i
                
                If Trim(wsSource.Range("E" & caRow).Value) <> "" _
                Or Trim(wsSource.Range("E" & paRow).Value) <> "" Then
                    
                    
                    wsDest.Cells(outputRow, "A").Value = localID
                    
                    
                    'Corrective Actions
                    wsDest.Cells(outputRow, "C").Value = wsSource.Range("E" & caRow).Value
                    wsDest.Cells(outputRow, "D").Value = wsSource.Range("AD" & caRow).Value
                    wsDest.Cells(outputRow, "E").Value = wsSource.Range("AN" & caRow).Value
                    wsDest.Cells(outputRow, "F").Value = wsSource.Range("AY" & caRow).Value
                    
                    
                    'Preventive Actions
                    wsDest.Cells(outputRow, "G").Value = wsSource.Range("E" & paRow).Value
                    wsDest.Cells(outputRow, "H").Value = wsSource.Range("AD" & paRow).Value
                    wsDest.Cells(outputRow, "I").Value = wsSource.Range("AN" & paRow).Value
                    wsDest.Cells(outputRow, "J").Value = wsSource.Range("AY" & paRow).Value
                    
                    
                    outputRow = outputRow + 1
                    
                End If
                
            Next i
            
            
            wb.Close SaveChanges:=False
            
        End If
        
        
        fileName = Dir
        
    Loop
    
    
    Unload frmLoading
    
    Application.DisplayAlerts = True
    Application.ScreenUpdating = True
    
    
    MsgBox "CAPA extraction complete." & vbCrLf & _
           outputRow - 2 & " records extracted.", vbInformation

End Sub
