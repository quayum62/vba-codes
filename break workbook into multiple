Sub ExportSheetsAsWorkbooks()

    Dim ws As Worksheet
    Dim newWb As Workbook
    Dim savePath As String
    Dim fileName As String
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    'Destination folder
    savePath = "C:\Users\bxb9893\OneDrive - JT International\Documents\!Tahseen Quayum\5000 IMS & QMS\QUIP\All QUIP CAPAs\"
    
    'Loop through all sheets
    For Each ws In ThisWorkbook.Worksheets
        
        'Copy sheet to a new workbook
        ws.Copy
        
        Set newWb = ActiveWorkbook
        
        'Clean filename from sheet name
        fileName = ws.Name
        fileName = Replace(fileName, "\", "_")
        fileName = Replace(fileName, "/", "_")
        fileName = Replace(fileName, ":", "_")
        fileName = Replace(fileName, "*", "_")
        fileName = Replace(fileName, "?", "_")
        fileName = Replace(fileName, """", "_")
        fileName = Replace(fileName, "<", "_")
        fileName = Replace(fileName, ">", "_")
        fileName = Replace(fileName, "|", "_")
        
        'Save workbook
        newWb.SaveAs Filename:=savePath & fileName & ".xlsx", _
                     FileFormat:=xlOpenXMLWorkbook
        
        newWb.Close SaveChanges:=False
        
    Next ws
    
    Application.DisplayAlerts = True
    Application.ScreenUpdating = True
    
    MsgBox "All sheets exported successfully!", vbInformation

End Sub
